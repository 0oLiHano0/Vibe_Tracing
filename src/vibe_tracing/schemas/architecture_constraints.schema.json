{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vibe-tracing/schemas/architecture_constraints.schema.json",
  "title": "ArchitectureConstraints",
  "description": "Schema for the Vibe Tracing architecture_constraints.json file.",
  "type": "object",
  "required": [
    "schema_version",
    "project"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "指明当前架构约束模式的版本，例如 '1.0.0'。"
    },
    "project": {
      "type": "object",
      "required": [
        "project_id",
        "name",
        "stage"
      ],
      "additionalProperties": false,
      "properties": {
        "project_id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_-]+$",
          "description": "项目唯一标识符"
        },
        "name": {
          "type": "string",
          "description": "项目名称，人类可读字符串。"
        },
        "description": {
          "type": "string",
          "description": "项目详细说明。"
        },
        "stage": {
          "type": "string",
          "description": "项目当前阶段（如 mvp、alpha、beta、production）。"
        },
        "language": {
          "type": "string",
          "description": "项目使用的编程语言（如 python、javascript、go），由 Agent 在架构设计阶段确定。finalize 命令从此字段读取语言并同步到 config.json。"
        }
      }
    },
    "architecture_principles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "principle_id",
          "title",
          "description",
          "severity"
        ],
        "additionalProperties": false,
        "properties": {
          "principle_id": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9_-]+$"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "must",
              "should",
              "could"
            ],
            "description": "强度级别，必须为 'must'、'should' 或 'could' 之一。"
          },
          "related_requirements": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-zA-Z0-9_-]+$"
            }
          },
          "verification_method": {
            "type": "string",
            "enum": [
              "machine",
              "manual"
            ],
            "description": "Whether this rule can be automatically verified by VT (machine) or requires human review (manual). Manual rules are acknowledged but do not block the gate."
          },
          "accepted_by": {
            "type": [
              "string",
              "null"
            ],
            "description": "Name or identifier of the human who accepted this manual rule. Null if not yet accepted."
          },
          "accepted_at": {
            "type": [
              "string",
              "null"
            ],
            "description": "ISO 8601 timestamp of when this manual rule was accepted. Null if not yet accepted."
          }
        }
      }
    },
