{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vibe-tracing/schemas/traceability_report.schema.json",
  "title": "TraceabilityReport",
  "description": "Schema for the final traceability report produced by Vibe Tracing.",
  "type": "object",
  "required": [
    "run_id",
    "project_id",
    "scan_time",
    "gate_decision",
    "requirement_coverage",
    "gaps",
    "risks"
  ],
  "additionalProperties": true,
  "properties": {
    "run_id": {
      "type": "string",
      "description": "Unique identifier for this report run."
    },
    "project_id": {
      "type": "string",
      "pattern": "^PROJECT-[a-zA-Z0-9_-]+$",
      "description": "Project identifier."
    },
    "scan_time": {
      "type": "string",
      "description": "ISO-8601 timestamp when the report was generated."
    },
    "gate_decision": {
      "type": "string",
      "enum": ["pass", "fail", "blocked", "draft_approved"],
      "description": "Overall quality gate decision for this run."
    },
    "requirement_coverage": {
      "type": "array",
      "description": "Coverage status for each requirement.",
      "items": {
        "type": "object",
        "required": ["req_id", "status", "evidence_ids"],
        "additionalProperties": true,
        "properties": {
          "req_id": {
            "type": "string",
            "pattern": "^REQ-[a-zA-Z0-9_-]+-\\d+$",
            "description": "Requirement identifier."
          },
          "status": {
            "type": "string",
            "enum": [
              "covered",
              "partial",
              "missing",
              "unclear",
              "low_confidence",
              "blocked",
              "compliant",
              "violated"
            ],
            "description": "Coverage status for this requirement."
          },
          "evidence_ids": {
            "type": "array",
            "description": "Evidence IDs that support the status.",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "gaps": {
      "type": "array",
      "description": "List of identified gaps in traceability coverage.",
      "items": {
        "type": "object",
        "required": ["item_id", "item_type", "reason"],
        "additionalProperties": true,
        "properties": {
          "item_id": {
            "type": "string",
            "description": "ID of the item with a gap."
          },
          "item_type": {
            "type": "string",
            "description": "Type of the item (e.g., requirement, AC)."
          },
          "reason": {
            "type": "string",
            "description": "Why this gap exists."
          }
        }
      }
    },
    "risks": {
      "type": "array",
      "description": "List of identified risks.",
      "items": {
        "type": "object",
        "required": ["risk_id", "description", "severity"],
        "additionalProperties": true,
        "properties": {
          "risk_id": {
            "type": "string",
            "pattern": "^RISK-[a-zA-Z0-9_-]+-\\d+$",
            "description": "Unique risk identifier."
          },
          "description": {
            "type": "string",
            "description": "Human-readable description of the risk."
          },
          "severity": {
            "type": "string",
            "enum": ["must", "should", "could"],
            "description": "Severity level of the risk."
          }
        }
      }
    }
  }
}
