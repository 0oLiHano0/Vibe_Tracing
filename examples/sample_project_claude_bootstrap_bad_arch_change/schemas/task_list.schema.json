{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vibe-tracing/schemas/task_list.schema.json",
  "title": "TaskList",
  "description": "Schema for the Vibe Tracing task_list.json file.",
  "type": "object",
  "required": ["schema_version", "project", "tasks"],
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Version of this schema."
    },
    "project": {
      "type": "object",
      "description": "Top-level project metadata.",
      "required": ["project_id", "name", "stage"],
      "additionalProperties": true,
      "properties": {
        "project_id": {
          "type": "string",
          "pattern": "^PROJECT-VT$",
          "description": "Unique project identifier."
        },
        "name": {
          "type": "string",
          "description": "Human-readable project name."
        },
        "stage": {
          "type": "string",
          "description": "Current project stage."
        }
      }
    },
    "tasks": {
      "type": "array",
      "description": "List of all task objects.",
      "items": {
        "type": "object",
        "required": [
          "task_id",
          "title",
          "phase_id",
          "priority",
          "status",
          "owner_role",
          "objective",
          "related_requirements",
          "related_acceptance_criteria",
          "definition_of_done"
        ],
        "additionalProperties": true,
        "properties": {
          "task_id": {
            "type": "string",
            "pattern": "^TASK-VT-\\d+$",
            "description": "Unique task identifier."
          },
          "title": {
            "type": "string",
            "description": "Short task title."
          },
          "phase_id": {
            "type": "string",
            "pattern": "^PHASE-VT-\\d+$",
            "description": "Phase this task belongs to."
          },
          "priority": {
            "type": "string",
            "enum": ["must", "should", "could"],
            "description": "MoSCoW priority level."
          },
          "status": {
            "type": "string",
            "enum": ["todo", "in_progress", "blocked", "done"],
            "description": "Current task status."
          },
          "owner_role": {
            "type": "string",
            "description": "Role responsible for this task."
          },
          "objective": {
            "type": "string",
            "description": "What this task aims to achieve."
          },
          "related_requirements": {
            "type": "array",
            "description": "Requirement IDs this task addresses.",
            "items": {
              "type": "string",
              "pattern": "^REQ-VT-\\d+$"
            }
          },
          "related_acceptance_criteria": {
            "type": "array",
            "description": "Acceptance criteria IDs this task addresses.",
            "items": {
              "type": "string",
              "pattern": "^AC-VT-\\d+-\\d+$"
            }
          },
          "definition_of_done": {
            "type": "array",
            "description": "Checklist items that define completion.",
            "items": {
              "type": "object",
              "required": ["dod_id", "description"],
              "additionalProperties": true,
              "properties": {
                "dod_id": {
                  "type": "string",
                  "pattern": "^DOD-VT-\\d+-\\d+$",
                  "description": "Unique DoD item identifier."
                },
                "description": {
                  "type": "string",
                  "description": "What must be true for this DoD item to be satisfied."
                }
              }
            }
          }
        }
      }
    }
  }
}
