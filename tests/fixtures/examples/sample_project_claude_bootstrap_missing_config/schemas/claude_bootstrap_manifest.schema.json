{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Claude Code Bootstrap Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "runtime",
    "subagents",
    "skills",
    "forbidden_actions",
    "structured_governance_outputs"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "runtime": {
      "type": "string",
      "pattern": "^claude-code$"
    },
    "subagents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "definition_file", "role"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^SUBAGENT-VT-\\d+$"
          },
          "name": {
            "type": "string"
          },
          "definition_file": {
            "type": "string"
          },
          "role": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "definition_file", "purpose"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^SKILL-VT-\\d+$"
          },
          "name": {
            "type": "string"
          },
          "definition_file": {
            "type": "string"
          },
          "purpose": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "forbidden_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "structured_governance_outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
