{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Claude Code Skill Definition",
  "type": "object",
  "required": [
    "skill_id",
    "name",
    "purpose",
    "inputs",
    "outputs",
    "boundaries",
    "constraints"
  ],
  "properties": {
    "skill_id": {
      "type": "string",
      "pattern": "^SKILL-VT-\\d+$"
    },
    "name": {
      "type": "string"
    },
    "purpose": {
      "type": "string"
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "boundaries": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
