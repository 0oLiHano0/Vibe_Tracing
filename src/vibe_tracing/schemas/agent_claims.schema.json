{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vibe-tracing/schemas/agent_claims.schema.json",
  "title": "AgentClaims",
  "description": "Schema for agent_claims.json — a top-level array of claim objects.",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "claim_id",
      "related_task"
    ],
    "additionalProperties": true,
    "properties": {
      "claim_id": {
        "type": "string",
        "pattern": "^CLAIM-[a-zA-Z0-9_-]+-\\d+$",
        "description": "申索唯一标识符"
      },
      "related_task": {
        "type": "string",
        "pattern": "^TASK-[a-zA-Z0-9_-]+-\\d+$",
        "description": "关联任务标识符"
      },
      "code_refs": {
        "type": "array",
        "description": "可选的源代码参考路径列表。",
        "items": {
          "type": "string"
        }
      },
      "test_refs": {
        "type": "array",
        "description": "可选的测试文件参考路径列表。",
        "items": {
          "type": "string"
        }
      },
      "notes": {
        "type": "string",
        "description": "可选的备注说明信息。"
      }
    }
  }
}
